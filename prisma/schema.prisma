generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  DIRECTOR   // 事业部负责人
  MANAGER    // 区域经理
  SUPERVISOR // 团队主管（兼外勤）
  SALES      // 一线业务员
}

enum UserStatus {
  ACTIVE   // 正常
  RESIGNED // 离职
  DISABLED // 停用
}

/** 账号开通与实名认证生命周期 */
enum AccountLifecycle {
  IMPORTED           // Excel 导入，未开通登录
  PENDING_ONBOARDING // 经理已开通，待完成实名认证
  ACTIVE             // 已完成实名认证
}

enum DataMode {
  MANUAL_UPLOAD // 人工上传 Excel
  API_SYNC      // P 站 API 自动拉取
}

enum PhotoStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RiskStatus {
  PENDING
  PASSED
  FAILED
}

enum SalesActivationStatus {
  NOT_ACTIVATED // 未动销（照片未通过，动销未启动）
  ACTIVATED     // 已动销
  IN_PROGRESS   // 待动销达标（照片已通过，笔数未达标）
}

enum OrgUnitType {
  DIVISION // 事业部
  REGION   // 区域
  TEAM     // 团队
}

enum ImportStatus {
  PENDING
  PROCESSING
  SUCCESS
  PARTIAL
  FAILED
}

enum AnomalyType {
  NAME_MISMATCH // P 站姓名与后台不匹配
  DUPLICATE     // 重复数据（已跳过）
  DIRTY_DATA    // 脏数据
}

enum ApiSyncStatus {
  RUNNING
  SUCCESS
  FAILED
}

// ─── Organization ────────────────────────────────────────────────────────────

model OrgUnit {
  id        String      @id @default(cuid())
  name      String
  type      OrgUnitType
  parentId  String?
  parent    OrgUnit?    @relation("OrgHierarchy", fields: [parentId], references: [id])
  children  OrgUnit[]   @relation("OrgHierarchy")
  users     User[]
  merchants MerchantRecord[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([parentId])
  @@index([type])
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id               String            @id @default(cuid())
  username         String            @unique
  passwordHash     String?           // null = 未开通登录
  name             String            // 真实姓名
  aliases          String[]          @default([]) // 兼容旧匹配，逐步迁移至 SalesPlatformIdentity
  role             UserRole
  status           UserStatus        @default(ACTIVE)
  accountLifecycle   AccountLifecycle  @default(IMPORTED)
  mustChangePassword Boolean           @default(false)
  /** 可访问业务线：xlh / n7；负责人忽略此字段（始终全开） */
  businessLines      String[]          @default(["xlh", "n7"])
  teamId           String?
  team             OrgUnit?          @relation(fields: [teamId], references: [id])
  managerId        String?
  manager          User?             @relation("UserHierarchy", fields: [managerId], references: [id])
  subordinates     User[]            @relation("UserHierarchy")
  profile          UserProfile?
  platformIdentities SalesPlatformIdentity[]
  merchants        MerchantRecord[]
  n7DevicesAsSales   N7DeviceRecord[] @relation("N7DeviceSales")
  n7DevicesAsManager N7DeviceRecord[] @relation("N7DeviceManager")
  teamHistory      UserTeamHistory[]
  importLogs       ImportLog[]
  heavyImportJobs  HeavyImportJob[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([teamId])
  @@index([managerId])
  @@index([name])
  @@index([role, status])
  @@index([accountLifecycle])
}

model UserProfile {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone     String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/** 业务员 P 站认证身份（作业账号 + 个人 PID，可多个） */
model SalesPlatformIdentity {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobAccountName String   // 对应 P 站「员工名称」，全站唯一
  personalPid    String   // 业务员个人 PID，一期仅存储
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([jobAccountName])
  @@index([userId])
  @@index([personalPid])
}

// 人员调动历史：历史数据保留原团队
model UserTeamHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId    String
  teamName  String
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([teamId])
}

// ─── Business Data ───────────────────────────────────────────────────────────

model Opportunity {
  id        String           @id @default(cuid())
  name      String           @unique
  code      String?          @unique
  merchants MerchantRecord[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model MerchantRecord {
  id                    String                @id @default(cuid())
  jobNumber             String                @unique // 作业编号，去重主键
  merchantPid           String?               // 商家 PID（可重复，同一商户多条作业）
  merchantName          String
  merchantType          String?               // 商户类型 A/B/C（来自 P 站表格）
  salesUserId           String?               // 匹配到的后台用户
  salesUser             User?                 @relation(fields: [salesUserId], references: [id])
  salesUserName         String                // P 站原始业务员姓名
  teamId                String?               // 入库时的团队归属（含历史快照）
  team                  OrgUnit?              @relation(fields: [teamId], references: [id])
  opportunityId         String?
  opportunity           Opportunity?          @relation(fields: [opportunityId], references: [id])
  opportunityName       String?
  photoStatus           PhotoStatus           @default(PENDING)
  riskStatus            RiskStatus            @default(PENDING)
  salesActivationStatus SalesActivationStatus @default(NOT_ACTIVATED)
  riskFailReason        String?
  expandDate            DateTime
  touchCount15d         Int                   @default(0) // 15 天有效碰笔数
  scanCount15d          Int                   @default(0) // 15 天有效扫码数
  transactionCount30d   Int                   @default(0) // 30 天有效交易笔数
  sourceMode            DataMode              @default(MANUAL_UPLOAD)
  importBatchId         String?
  importBatch           ImportLog?            @relation(fields: [importBatchId], references: [id])
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([salesUserId])
  @@index([teamId])
  @@index([opportunityId])
  @@index([expandDate])
  @@index([photoStatus])
  @@index([riskStatus])
  @@index([salesActivationStatus])
  @@index([merchantPid])
}

// ─── System Config ───────────────────────────────────────────────────────────

model SystemConfig {
  id               String   @id @default("singleton")
  dataMode         DataMode @default(MANUAL_UPLOAD)
  apiUrl           String?
  apiKey           String?
  apiTimeoutMs     Int      @default(30000)
  apiRetryCount    Int      @default(3)
  syncCron         String   @default("10 0 * * *") // 每日 00:10
  syncFrequency    String   @default("daily")      // hourly | daily
  lastSyncAt       DateTime?
  updatedAt        DateTime @updatedAt
}

// ─── Logs & Anomalies ────────────────────────────────────────────────────────

model ImportLog {
  id             String           @id @default(cuid())
  fileName       String
  uploadedById   String
  uploadedBy     User             @relation(fields: [uploadedById], references: [id])
  status         ImportStatus     @default(PENDING)
  totalRows      Int              @default(0)
  importedRows   Int              @default(0)
  skippedRows    Int              @default(0)
  anomalyRows    Int              @default(0)
  errorMessage   String?
  merchants      MerchantRecord[]
  n7Devices      N7DeviceRecord[]
  createdAt      DateTime         @default(now())
  completedAt    DateTime?

  @@index([uploadedById])
  @@index([createdAt])
}

/** 大表导入异步任务（上传后立即返回 jobId，后台处理，前端轮询） */
model HeavyImportJob {
  id           String       @id @default(cuid())
  /** personnel | n7 | xlh-excel */
  kind         String
  fileName     String
  status       ImportStatus @default(PENDING)
  progress     Int          @default(0)
  message      String?
  resultJson   Json?
  errorMessage String?
  uploadedById String
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  completedAt  DateTime?

  @@index([uploadedById, createdAt])
  @@index([status, createdAt])
}

// ─── N7 机具考核（按设备 SN）────────────────────────────────────────────────

/** 支付宝 N7：以设备 SN 为考核单元的导入明细 */
model N7DeviceRecord {
  id                 String    @id @default(cuid())
  deviceSn           String    @unique
  registeredAt       DateTime?
  litAt              DateTime?
  subscribedAt       DateTime?
  firstCheckInAt     DateTime?
  notLit             Boolean   @default(false)
  notSubscribed      Boolean   @default(false)
  notCheckedIn       Boolean   @default(false)
  assessmentStartAt  DateTime?
  assessmentEndAt    DateTime?
  /** 剩余考核天数；已结束为 null 且 remainingEnded=true；未进考核期两者皆空/false */
  remainingDays      Int?
  remainingEnded     Boolean   @default(false)
  effectiveDays      Int       @default(0)
  effectiveUsers     Int       @default(0)
  isQualified        Boolean   @default(false)
  operatorName       String
  managerName        String
  companyName        String?
  phase2Days         Int       @default(0)
  phase2Users        Int       @default(0)
  storeId            String?
  storeName          String?
  storeAddress       String?
  storePhone         String?
  merchantId         String?
  merchantAccount    String?
  merchantPhone      String?
  salesUserId        String?
  salesUser          User?     @relation("N7DeviceSales", fields: [salesUserId], references: [id])
  managerUserId      String?
  managerUser        User?     @relation("N7DeviceManager", fields: [managerUserId], references: [id])
  /** 处理状态：是否已处理（Excel 重导不覆盖；与考核「待跟进」独立） */
  followUpDone       Boolean   @default(false)
  followUpNote       String?
  followUpAt         DateTime?
  followUpById       String?
  sourceMode         DataMode  @default(MANUAL_UPLOAD)
  importBatchId      String?
  importBatch        ImportLog? @relation(fields: [importBatchId], references: [id])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([salesUserId])
  @@index([managerUserId])
  @@index([managerName])
  @@index([operatorName])
  @@index([registeredAt])
  @@index([isQualified])
  @@index([remainingEnded, remainingDays])
  @@index([storeId])
  @@index([followUpDone])
}

model ApiSyncLog {
  id           String        @id @default(cuid())
  status       ApiSyncStatus @default(RUNNING)
  triggeredBy  String?       // manual | cron
  totalRows    Int           @default(0)
  importedRows Int           @default(0)
  skippedRows  Int           @default(0)
  anomalyRows  Int           @default(0)
  errorMessage String?
  startedAt    DateTime      @default(now())
  completedAt  DateTime?

  @@index([startedAt])
}

model AnomalyRecord {
  id            String      @id @default(cuid())
  type          AnomalyType
  rawData       Json
  salesUserName String?
  jobNumber     String?
  merchantPid   String?
  reason        String
  resolved      Boolean     @default(false)
  matchedUserId String?
  importBatchId String?
  apiSyncLogId  String?
  createdAt     DateTime    @default(now())
  resolvedAt    DateTime?

  @@index([type, resolved])
  @@index([salesUserName])
}

model SystemAlert {
  id        String   @id @default(cuid())
  level     String   @default("warning") // info | warning | error
  message   String
  source    String   // import | api | system
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read, createdAt])
}
